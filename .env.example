# LynxNetStack root environment variables
# Copy to .env and fill in real values before running docker compose.
# Per-component secrets also go in their own config files (see AGENTS.md).

# ── Domain ────────────────────────────────────────────────────────────────────
PUBLIC_HOST=jake.lynxnet.co

# ── NetBox ────────────────────────────────────────────────────────────────────
NETBOX_URL=http://172.27.48.233:8001
NETBOX_API_TOKEN=

# ── BigMac (RouterOS API proxy) ───────────────────────────────────────────────
BIGMAC_URL=http://172.27.226.246:8081

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://172.27.72.179:9090

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Use test keys (sk_test_...) until confirmed working end-to-end
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── LynxMSP ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LYNXMSP_SECRET_KEY=change-me-in-production

# ── kea-sync (runs on jumpB, NOT in this compose) ────────────────────────────
# Documented here for reference. Set in jumpB's kea-sync/config/.env.
# KEA_API_URL=http://127.0.0.1:8000   (localhost on jumpB — no auth needed)
