# LynxNetStack root environment variables
# Copy to .env and fill in real values.
# Per-component secrets go in their own config files (see AGENTS.md).

# ── NetBox ────────────────────────────────────────────────────────────────────
NETBOX_URL=http://172.27.48.233:8001
NETBOX_API_TOKEN=

# ── Kea DHCP4 ─────────────────────────────────────────────────────────────────
KEA_API_URL=http://172.27.28.50:8000

# ── BigMac (RouterOS API proxy) ───────────────────────────────────────────────
BIGMAC_URL=http://172.27.226.246:8081

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://172.27.72.179:9090

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Use test keys (sk_test_...) until confirmed working end-to-end
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── LynxMSP ───────────────────────────────────────────────────────────────────
LYNXMSP_SECRET_KEY=change-me-in-production

# ── Kea Sync ──────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
DRY_RUN=false
