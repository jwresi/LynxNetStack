# kea-sync environment configuration
# Run kea-sync on jumpB — the Kea control agent only listens on loopback.
# Copy to .env and set NETBOX_TOKEN before running.

# Kea DHCP4 control agent (localhost on jumpB — no auth needed)
KEA_API_URL=http://127.0.0.1:8000

# NetBox
NETBOX_URL=http://172.27.48.233:8001
NETBOX_TOKEN=

# Polling interval in seconds
POLL_INTERVAL_SECONDS=60

# Set to true to log changes without writing to NetBox
DRY_RUN=false
