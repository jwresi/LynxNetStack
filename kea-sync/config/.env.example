# kea-sync environment configuration
# Copy to .env and fill in KEA_API_PASSWORD and NETBOX_TOKEN before running.

# Kea DHCP4 control agent
# jumpB ZeroTier IP: 172.27.209.248  Primary LAN IP: 172.16.1.125
# The control agent listens on 127.0.0.1:8000 on jumpB; reach it via ZT.
KEA_API_URL=http://172.27.209.248:8000

# HTTP Basic Auth for Kea control agent (from /etc/kea/kea-api-secret on jumpB)
# The secret file is in htpasswd format: user:password
# Read it with: sudo cat /etc/kea/kea-api-secret
KEA_API_USER=kea
KEA_API_PASSWORD=

# NetBox
NETBOX_URL=http://172.27.48.233:8001
NETBOX_TOKEN=

# Polling interval in seconds
POLL_INTERVAL_SECONDS=60

# Set to true to log changes without writing to NetBox
DRY_RUN=false
