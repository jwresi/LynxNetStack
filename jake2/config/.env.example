# Jake2 environment template
# Place real values in config/.env or export them in the shell.
# Do not commit live secrets, tokens, passwords, or client certificates.

# Core paths
# Used by core/shared.py and runtime loaders to resolve the repo root.
JAKE_ROOT=/Users/you/projects/jake2
# Optional explicit env file path used by launch tooling.
JAKE_ENV_FILE=config/.env

# Local data / artifacts
# Path to the runtime-generated deterministic core DB snapshot.
JAKE_OPS_DB=data/network_map.db
# Path to the NYCHA source CSV consumed by mcp/jake_ops_mcp.py and audits/jake_audit_workbook.py.
JAKE_NYCHA_INFO_CSV=data/nycha_info.csv
# Path to the TAUC NYCHA audit CSV consumed by mcp/jake_ops_mcp.py and audits/jake_audit_workbook.py.
JAKE_TAUC_AUDIT_CSV=output/tauc_nycha_cpe_audit_latest.csv
# Path to the Vilo inventory snapshot consumed by audits/jake_audit_workbook.py.
JAKE_VILO_INVENTORY_SNAPSHOT=data/vilo_inventory_latest.json
# Optional script path for generating or refreshing online CPE data.
JAKE_LIST_ONLINE_CPES_SCRIPT=scripts/list_online_cpes.py
# Optional local online CPE CSV consumed as deterministic corroboration.
JAKE_LOCAL_ONLINE_CPE_CSV=output/online_cpes_latest.csv
# AnythingLLM MCP server config consumed by mcp/jake_ops_mcp.py.
JAKE_ANYTHINGLLM_MCP_CONFIG=config/anythingllm_mcp_servers.json

# Audit / workbook config
# Donor workbook template consumed by audits/jake_audit_workbook.py and audits/batch_nycha_audit_summary.py.
JAKE_AUDIT_TEMPLATE_WORKBOOK=tests/fixtures/audit/nycha_template.xlsx

# RAG / references
# Optional Python interpreter for the isolated RAG helper in mcp/jake_ops_mcp.py.
JAKE_RAG_PYTHON=.venv/bin/python
# Optional root directory for the isolated RAG helper.
JAKE_RAG_ROOT=references/rag
# Optional query script path for the isolated RAG helper.
JAKE_RAG_QUERY_SCRIPT=references/rag/query.py

# MCP / SSH inventory
# Root of the external ssh_mcp checkout consumed by mcp/jake_ops_mcp.py.
SSH_MCP_ROOT=external/ssh_mcp
# Source package path for ssh_mcp dynamic loading.
JAKE_SSH_MCP_SRC=external/ssh_mcp/src
# Device access username consumed by mcp/jake_ops_mcp.py for RouterOS API access.
SSH_MCP_USERNAME=replace_me
# Device access password consumed by mcp/jake_ops_mcp.py and ssh_mcp-backed live reads.
SSH_MCP_PASSWORD=replace_me

# NetBox
# Base URL consumed by mcp/jake_ops_mcp.py.
NETBOX_URL=https://netbox.example.com
# API token consumed by mcp/jake_ops_mcp.py.
NETBOX_TOKEN=replace_me

# Alertmanager
# Base URL consumed by mcp/jake_ops_mcp.py.
ALERTMANAGER_URL=https://alertmanager.example.com

# Bigmac
# Base URL consumed by mcp/jake_ops_mcp.py.
BIGMAC_URL=https://bigmac.example.com
# Username consumed by mcp/jake_ops_mcp.py.
BIGMAC_USER=replace_me
# Password consumed by mcp/jake_ops_mcp.py.
BIGMAC_PASSWORD=replace_me

# cnWave / Cambium
# Exporter URL consumed by mcp/jake_ops_mcp.py and mcp/vendor_adapters.py.
CNWAVE_EXPORTER_URL=https://cnwave-exporter.example.com
# Controller base URL consumed by mcp/vendor_adapters.py.
CNWAVE_CONTROLLER_URL=https://cnwave-controller.example.com
# Controller username consumed by mcp/vendor_adapters.py.
CNWAVE_CONTROLLER_USERNAME=replace_me
# Controller password consumed by mcp/vendor_adapters.py.
CNWAVE_CONTROLLER_PASSWORD=replace_me
# Legacy Cambium username consumed by mcp/vendor_adapters.py when mapping old envs.
CAMBIUM_USERNAME=replace_me
# Legacy Cambium password consumed by mcp/vendor_adapters.py when mapping old envs.
CAMBIUM_PASSWORD=replace_me

# Siklu
# Username consumed by older radio paths and inventory helpers.
SIKLU_USERNAME=replace_me
# Password consumed by older radio paths and inventory helpers.
SIKLU_PASSWORD=replace_me

# Vilo API / portal
# App key consumed by mcp/vilo_mcp.py.
VILO_APPKEY=replace_me
# App secret consumed by mcp/vilo_mcp.py.
VILO_APPSECRET=replace_me
# Optional portal token consumed by vendor-facing Vilo helpers.
VILO_PORTAL_TOKEN=replace_me

# TAUC / TP-Link
# Primary login email consumed by mcp/jake_ops_mcp.py web login flow.
TAUC_EMAIL=replace_me@example.com
# Legacy TP-Link ID email consumed by old Jake compatibility paths.
TPLINK_ID_EMAIL=replace_me@example.com
# Primary TAUC password consumed by mcp/jake_ops_mcp.py and normalized from legacy envs.
TAUC_PASSWORD=replace_me
# Legacy TP-Link password retained for compatibility mapping into TAUC_PASSWORD.
TPLINK_ID_PASSWORD=replace_me
# Toggle for TAUC TLS verification consumed by mcp/tauc_mcp.py and mcp/vendor_adapters.py.
TAUC_VERIFY_SSL=true
# Shared TAUC client credentials consumed by mcp/tauc_mcp.py.
TAUC_CLIENT_ID=replace_me
TAUC_CLIENT_SECRET=replace_me
TAUC_CLIENT_CERT=config/certs/client.crt
TAUC_CLIENT_KEY=config/certs/client.key
TAUC_CLIENT_KEY_PASSWORD=replace_me
TAUC_SECRET_KEY=replace_me
# Cloud endpoint credentials consumed by mcp/tauc_mcp.py.
TAUC_CLOUD_BASE_URL=https://tauc-cloud.example.com
TAUC_CLOUD_AUTH_TYPE=client_credentials
TAUC_CLOUD_ACCESS_KEY=replace_me
TAUC_CLOUD_SECRET_KEY=replace_me
TAUC_CLOUD_CLIENT_ID=replace_me
TAUC_CLOUD_CLIENT_SECRET=replace_me
TAUC_CLOUD_CLIENT_CERT=config/certs/client.crt
TAUC_CLOUD_CLIENT_KEY=config/certs/client.key
TAUC_CLOUD_CLIENT_KEY_PASSWORD=replace_me
TAUC_CLOUD_CA_CERT=config/certs/ca.crt
# ACS endpoint credentials consumed by mcp/tauc_mcp.py.
TAUC_ACS_BASE_URL=https://tauc-acs.example.com
TAUC_ACS_AUTH_TYPE=client_credentials
TAUC_ACS_ACCESS_KEY=replace_me
TAUC_ACS_SECRET_KEY=replace_me
TAUC_ACS_CLIENT_ID=replace_me
TAUC_ACS_CLIENT_SECRET=replace_me
TAUC_ACS_CLIENT_CERT=config/certs/client.crt
TAUC_ACS_CLIENT_KEY=config/certs/client.key
TAUC_ACS_CLIENT_KEY_PASSWORD=replace_me
TAUC_ACS_CA_CERT=config/certs/ca.crt
# OLT endpoint credentials consumed by mcp/tauc_mcp.py.
TAUC_OLT_BASE_URL=https://tauc-olt.example.com
TAUC_OLT_AUTH_TYPE=client_credentials
TAUC_OLT_ACCESS_KEY=replace_me
TAUC_OLT_SECRET_KEY=replace_me
TAUC_OLT_CLIENT_ID=replace_me
TAUC_OLT_CLIENT_SECRET=replace_me
TAUC_OLT_CLIENT_CERT=config/certs/client.crt
TAUC_OLT_CLIENT_KEY=config/certs/client.key
TAUC_OLT_CLIENT_KEY_PASSWORD=replace_me
TAUC_OLT_CA_CERT=config/certs/ca.crt

# OLT telnet
# Password consumed by mcp/jake_ops_mcp.py OLT telnet reads.
OLT_TELNET_PASSWORD=replace_me
# Legacy lower-case compatibility key still read by mcp/jake_ops_mcp.py.
olt_telnet_password=replace_me

# Positron / G.Hn
# Username consumed by mcp/jake_ops_mcp.py Positron reads.
POSITRON_USERNAME=replace_me
# Password consumed by mcp/jake_ops_mcp.py Positron reads.
POSITRON_PASSWORD=replace_me

# LynxMSP / LynxDHCP / Splynx
# Local DB path consumed by mcp/jake_ops_mcp.py LynxMSP joins.
LYNXMSP_DB_PATH=data/lynxcrm.db
# API base URL consumed by mcp/jake_ops_mcp.py live DHCP joins.
LYNXMSP_API_URL=http://127.0.0.1:8000
# Alternate API URL key retained for compatibility.
LYNX_API_URL=http://127.0.0.1:8010
# DHCP state path consumed by mcp/jake_ops_mcp.py.
LYNXDHCP_STATE_PATH=data/lynxdhcp_state.json
# Splynx API URL consumed by mcp/jake_ops_mcp.py.
SPLYNX_API_URL=https://crm.example.com
# Splynx API key consumed by mcp/jake_ops_mcp.py.
SPLYNX_KEY=replace_me
# Splynx API secret consumed by mcp/jake_ops_mcp.py.
SPLYNX_SECRET=replace_me

# Prometheus
# Base URL consumed by mcp/jake_ops_mcp.py new-device queries.
PROMETHEUS_URL=http://prometheus.example.com:9090

# Loki log filtering
# Comma-separated IPs of management servers whose API login/logout syslog lines should be filtered
# from Loki log summaries. Set to empty to disable.
JAKE_MGMT_IPS=172.27.72.179,172.27.226.246
# Set to false to disable Jake-side Loki noise filter.
JAKE_LOKI_FILTER_NOISE=true

# Ollama / understanding layer
# Endpoint consumed by agents/ollama_client.py and future intent parser.
OLLAMA_ENDPOINT=http://127.0.0.1:11434
# Model consumed by future intent parsing.
OLLAMA_MODEL=gemma4:26b
# Max seconds to wait for intent parsing.
OLLAMA_INTENT_TIMEOUT=15

# Slack / webhooks
# Optional webhook URL for any operator notifications or alerts.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me

# Misc legacy keys discovered during migration
# Older lowercase OLT usernames/passwords retained for inventory of required keys.
olt_user=replace_me
olt_password=replace_me
# Generic legacy keys discovered in old Jake. Jake2 should not consume these directly.
username=replace_me
password=replace_me
# Legacy AnythingLLM API key discovered in old tooling.
ANYTHINGLLM_API_KEY=replace_me
