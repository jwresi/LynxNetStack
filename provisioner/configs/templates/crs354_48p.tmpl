# RouterOS Configuration for {{ hostname }} (CRS354-48P-4S+2Q+RM)
# Generated: {{ now }}
# MAC: {{ mac }}
# Model: {{ model }}

/interface bridge
add admin-mac={{ mac }} auto-mac=no comment=defconf name=bridge vlan-filtering=yes
set [ find name=bridge ] protocol-mode=rstp

/interface vlan
add interface=bridge name=vlan{{ mgmtVlan }} vlan-id={{ mgmtVlan }}
add interface=bridge name=vlan{{ cxVlan }} vlan-id={{ cxVlan }}
add interface=bridge name=vlan{{ secVlan }} vlan-id={{ secVlan }}

/interface list
add name=WAN
add name=LAN
add name=CUSTOMER

/interface bridge port
{% for p in cxPorts %}add bridge=bridge comment=cx pvid={{ cxVlan }} interface={{ p }} horizon=1 edge=yes frame-types=admit-only-untagged-and-priority-tagged
{% endfor %}
add bridge=bridge comment=mgmt pvid={{ mgmtVlan }} interface={{ mgmtPort }} edge=yes frame-types=admit-only-untagged-and-priority-tagged
add bridge=bridge comment=sec pvid={{ secVlan }} interface={{ secPort }} edge=yes frame-types=admit-only-untagged-and-priority-tagged
{% for p in trunkIn %}add bridge=bridge comment=trunk-in frame-types=admit-only-vlan-tagged interface={{ p }}
{% endfor %}
{% for p in trunkOut %}add bridge=bridge comment=trunk-out frame-types=admit-only-vlan-tagged interface={{ p }}
{% endfor %}

/interface bridge vlan
add bridge=bridge tagged={{ (trunkIn + trunkOut)|join(',') }} untagged={{ cxPorts|join(',') }} vlan-ids={{ cxVlan }}
add bridge=bridge tagged={{ (trunkIn + trunkOut)|join(',') }} untagged={{ mgmtPort }} vlan-ids={{ mgmtVlan }}
add bridge=bridge tagged={{ (trunkIn + trunkOut)|join(',') }} untagged={{ secPort }} vlan-ids={{ secVlan }}

/interface list member
{% for p in cxPorts %}add interface={{ p }} list=LAN
{% endfor %}
{% for p in cxPorts %}add interface={{ p }} list=CUSTOMER
{% endfor %}
add interface={{ mgmtPort }} list=LAN
add interface={{ secPort }} list=LAN
{% for p in trunkIn %}add interface={{ p }} list=WAN
{% endfor %}
{% for p in trunkOut %}add interface={{ p }} list=LAN
{% endfor %}

/interface bridge port
{% for p in cxPorts %}set [ find where interface={{ p }} ] bpdu-guard=yes
{% endfor %}

/interface ethernet
{% for p in cxPorts %}set [ find name={{ p }} ] loop-protect=on loop-protect-disable-time=5m loop-protect-send-interval=5s
{% endfor %}

/interface ethernet
{% if poePorts %}{% for p in poePorts %}set [ find name={{ p }} ] poe-out=off
{% endfor %}{% endif %}

/ip firewall filter
add chain=forward in-interface-list=CUSTOMER protocol=udp dst-port=67,68 action=drop comment="Drop DHCP on customer ports"

/ip address
add address={{ ip }}/{{ subnet }} comment=defconf interface=vlan{{ mgmtVlan }} network={{ baseNetwork }}.0

/ip route
add dst-address=0.0.0.0/0 gateway={{ gateway }}

/system identity
set name={{ hostname }}

/system note
set show-at-login=no

/system ntp client servers
add address={{ ntpServer }}

/tool romon
set enabled=yes

