# LynxMSP Environment Configuration
# Copy this file to .env and update values for your environment

# Backend Configuration
SECRET_KEY=your-production-secret-key-change-me-to-something-secure
DATABASE_URL=sqlite:///data/lynxcrm.db
CORS_ORIGINS=http://localhost:3000,http://localhost:80,https://yourdomain.com

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# Development Only
CHOKIDAR_USEPOLLING=true

# Production Customization
# Uncomment and modify for production use
# COMPANY_NAME=Your Company Name
# COMPANY_DOMAIN=yourcompany.com
# ADMIN_EMAIL=admin@yourcompany.com

# Database Configuration (Advanced)
# For PostgreSQL/MySQL (future enhancement)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lynxmsp
# DB_USER=lynxmsp
# DB_PASSWORD=secure_password

# Security Settings
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (Future)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=true

# External Service Configuration (Future)
# MIKROTIK_DEFAULT_USER=admin
# MIKROTIK_DEFAULT_PASSWORD=
# SPLYNX_API_URL=https://your-splynx.com/api/2.0
# SPLYNX_API_KEY=your-api-key

# Monitoring and Logging
# LOG_LEVEL=INFO
# SENTRY_DSN=https://your-sentry-dsn
# ENABLE_METRICS=true

# Backup Configuration
# BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=30
# BACKUP_LOCATION=/backups